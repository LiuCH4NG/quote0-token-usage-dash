# dot.mindreset.tech credentials
QUOTE_API_KEY=dot_app_...
QUOTE_DEVICE_ID=XXXXXXXXXXXX

# Provider API keys
KIMI_API_KEY=your_kimi_api_key
GLM_API_KEY=your_glm_api_key

# Set to false to skip GLM fetching (default: true)
# GLM_ENABLED=false

# Seconds between updates in --loop mode (default: 1800)
# UPDATE_INTERVAL=1800

# Optional Dot Image API settings
# QUOTE_LINK=https://example.com
# QUOTE_BORDER=0
# QUOTE_DITHER_TYPE=NONE
# QUOTE_DITHER_KERNEL=
# QUOTE_TASK_KEY=
# QUOTE_TASK_ALIAS=
